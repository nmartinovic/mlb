# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Brevo (email)
EMAIL_API_KEY=xkeysib-xxxxx
FROM_EMAIL=highlights@ninthinning.email

# Cron secret (prevents unauthorized access to /api/cron)
CRON_SECRET=generate-a-random-string-here

# Admin email — single email address allowed to view /admin
ADMIN_EMAIL=you@example.com

# Site URL (for unsubscribe links in emails)
NEXT_PUBLIC_SITE_URL=https://ninthinning.email

# Kill switch: set to "true" to immediately pause all cron email sends (no redeploy needed)
EMAILS_PAUSED=

# Stripe Payment Link for the tip jar — production value lives in wrangler.jsonc;
# set this for local dev if you want the tip block to render.
TIP_URL=https://buy.stripe.com/YOUR_PAYMENT_LINK

# PostHog (browser analytics) — NEXT_PUBLIC_* values are inlined into the
# client bundle at `next build` time, so they MUST be set here (not just as
# Cloudflare Worker secrets) before `npm run deploy`. Leave empty to disable
# tracking in local dev. See the "Product analytics" section in CLAUDE.md.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
